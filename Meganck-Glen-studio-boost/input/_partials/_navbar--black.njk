<nav class="navbar navbar--black">
    <a class="navbar__logo--black" href="{{ '/' | url }}">
        Studio Boost
    </a>

    <ul class="nav__menu--black">
        {% for nav_item in collections.nav %}
            <li class="menu__item">
                <a class="menu__link {% if page.url == nav_item.page.url %} menu__link--active {% endif %}" href="{{ nav_item.page.url }}">
                    {{ nav_item.data.nav }}
                </a>
            </li>
        {% endfor %}
    </ul>
</nav>